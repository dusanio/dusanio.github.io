---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[#2a2a2a] mt-12 py-8">
  <div class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
    <p class="text-sm text-[#888888]">
      © {currentYear} Dusan Trajkovic
    </p>
    
    <div class="flex items-center gap-6">
      <a 
        href="https://github.com/dusanio" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-sm text-[#888888] hover:text-white transition-colors"
      >
        GitHub
      </a>
      <a 
        href="https://linkedin.com/in/dusanio" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-sm text-[#888888] hover:text-white transition-colors"
      >
        LinkedIn
      </a>
      <a 
        href="https://x.com/thedusanio" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-sm text-[#888888] hover:text-white transition-colors"
      >
        X
      </a>
      <a 
        href="https://t.me/dusanio" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-sm text-[#888888] hover:text-white transition-colors"
      >
        Telegram
      </a>
    </div>
  </div>
</footer>

